        document.getElementById('btn').addEventListener('touchstart', (e) => {
            e.preventDefault();
            for (let t of e.changedTouches) {
                score += clickPower; pending += clickPower;
                const p = document.createElement('div');
                p.className = 'plus-animation'; p.textContent = '+' + clickPower;
                p.style.left = t.pageX + 'px'; p.style.top = t.pageY + 'px';
                document.body.appendChild(p); setTimeout(() => p.remove(), 700);
            }
            scoreEl.textContent = Math.floor(score).toLocaleString();
            if (tg.HapticFeedback) tg.HapticFeedback.impactOccurred('medium');
        });

        setInterval(() => {
            if (pending > 0) {
                const s = pending; pending = 0;
                fetch('/api/clicks', {
                    method: 'POST',
                    headers: {'Content-Type': 'application/json'},
                    body: JSON.stringify({ user_id: userId, clicks: s })
                }).catch(() => { pending += s; });
            }
        }, 2000);

        loadData();
